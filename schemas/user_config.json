{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UserConfig",
  "type": "object",
  "properties": {
    "virtualHosts": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/VirtualHost"
      }
    }
  },
  "required": [
    "virtualHosts"
  ],
  "$defs": {
    "VirtualHost": {
      "type": "object",
      "properties": {
        "backends": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/BackendMCPGateway"
          }
        }
      },
      "required": [
        "backends"
      ]
    },
    "BackendMCPGateway": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "url"
      ]
    }
  }
}